---
import BaseLayout from "@/layouts/BaseLayout.astro";
import {
	projects,
	categoryLabels,
	categoryOrder,
	statusLabels,
	type Category,
	type Project,
} from "@/lib/projects";

const grouped = categoryOrder.reduce(
	(acc, cat) => {
		const items = projects.filter((p) => p.category === cat);
		if (items.length > 0) {
			acc.push({ category: cat, label: categoryLabels[cat], items });
		}
		return acc;
	},
	[] as { category: Category; label: string; items: Project[] }[],
);
---

<BaseLayout
	title="Projects — Stephen Sawyer"
	description="Active project roster. Self-hostable systems software in Go, C, and the web."
>
	<div class="projects-page">
		<h1>Projects</h1>
		<p class="lead">
			Everything is self-hostable, local-first, and designed to run on hardware you control.
		</p>

		{
			grouped.map((group) => (
				<section class="category-group">
					<h2>{group.label}</h2>
					<ul class="project-list" role="list">
						{group.items.map((project) => (
							<li class="project-card">
								<div class="project-header">
									<h3 class="project-name">{project.name}</h3>
									<span class={`status-badge status-${project.status}`}>
										{statusLabels[project.status]}
									</span>
								</div>
								<p class="project-tagline">{project.tagline}</p>
								<div class="project-meta">
									<div class="project-stack">
										{project.stack.map((tech) => (
											<span class="tech-tag">{tech}</span>
										))}
									</div>
									<a
										href={project.repo}
										target="_blank"
										rel="noopener noreferrer"
										class="repo-link"
									>
										repo →
									</a>
								</div>
							</li>
						))}
					</ul>
				</section>
			))
		}
	</div>
</BaseLayout>

<style>
	.projects-page {
		max-width: var(--content-width);
		margin: 0 auto;
	}

	.projects-page h1 {
		margin-bottom: var(--space-4);
	}

	.lead {
		color: var(--text-secondary);
		margin-bottom: var(--space-12);
	}

	.category-group {
		margin-bottom: var(--space-12);
	}

	.category-group h2 {
		font-size: var(--text-lg);
		color: var(--text-secondary);
		margin-bottom: var(--space-6);
		padding-bottom: var(--space-2);
		border-bottom: 1px solid var(--border);
	}

	.project-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-4);
	}

	.project-card {
		padding: var(--space-6);
		background-color: var(--bg-secondary);
		border: 1px solid var(--border);
		border-radius: var(--radius);
	}

	.project-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
		margin-bottom: var(--space-2);
	}

	.project-name {
		font-size: var(--text-base);
		font-weight: 500;
	}

	.status-badge {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		padding: var(--space-1) var(--space-2);
		border-radius: var(--radius);
		flex-shrink: 0;
	}

	.status-active {
		color: var(--success);
		background-color: #34d39910;
	}

	.status-shipped {
		color: var(--accent);
		background-color: var(--accent-muted);
	}

	.status-phase-0 {
		color: var(--warning);
		background-color: #fbbf2410;
	}

	.status-legacy {
		color: var(--text-tertiary);
		background-color: var(--bg-tertiary);
	}

	.project-tagline {
		color: var(--text-secondary);
		font-size: var(--text-sm);
		line-height: var(--leading-normal);
		margin: 0 0 var(--space-4);
	}

	.project-meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-4);
	}

	.project-stack {
		display: flex;
		gap: var(--space-2);
		flex-wrap: wrap;
	}

	.tech-tag {
		font-family: var(--font-mono);
		font-size: var(--text-xs);
		color: var(--text-tertiary);
		padding: var(--space-1) var(--space-2);
		border: 1px solid var(--border);
		border-radius: var(--radius);
	}

	.repo-link {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--accent);
		text-decoration: none;
		flex-shrink: 0;
		transition: color var(--duration-fast) var(--easing);
	}

	.repo-link:hover {
		color: var(--accent-hover);
	}
</style>
