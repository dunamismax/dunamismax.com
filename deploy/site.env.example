# Production environment file for dunamismax-site.service.
# Copy to /opt/dunamismax-site/site.env on the VM and fill in.

DUNAMISMAX_SITE_ADDR=127.0.0.1:3000
DUNAMISMAX_SITE_LOG=dunamismax_site=info,tower_http=info

DUNAMISMAX_DATABASE_URL=postgres://dunamismax:change-me@127.0.0.1:5432/dunamismax
DUNAMISMAX_DATABASE_MAX_CONNECTIONS=10
DUNAMISMAX_DATABASE_ACQUIRE_TIMEOUT_SECS=5
DUNAMISMAX_DATABASE_MIGRATE=true
