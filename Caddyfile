:80 {
	root * /srv
	encode zstd gzip

	# Clean URLs: try without .html extension
	try_files {path} {path}.html {path}/index.html

	# Custom 404
	handle_errors {
		@404 expression {err.status_code} == 404
		handle @404 {
			rewrite * /404.html
			file_server
		}
	}

	file_server

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "0"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	# Cache: fonts (1 year)
	@fonts path /fonts/*
	header @fonts Cache-Control "public, max-age=31536000, immutable"

	# Cache: hashed CSS and JS (1 year)
	@hashed path_regexp hashed \.(css|js)$
	header @hashed Cache-Control "public, max-age=31536000, immutable"

	# Cache: images and icons (1 week)
	@images path_regexp images \.(png|jpg|jpeg|gif|webp|avif|svg|ico)$
	header @images Cache-Control "public, max-age=604800"

	# Cache: HTML and feeds (no cache, always revalidate)
	@html path_regexp html \.(html|xml)$
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	# Default: HTML pages without extension
	@pages not path /fonts/* /feed.xml /sitemap* /_astro/*
	@pagesNotAsset not path_regexp \.(css|js|png|jpg|jpeg|gif|webp|avif|svg|ico|woff2|woff|ttf|eot)$
	header @pages ?Cache-Control "no-cache, no-store, must-revalidate"
}
