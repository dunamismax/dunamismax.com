---
import { siteConfig, socialLinks } from '../config/site'
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-text">{siteConfig.author} · Self-hostable software in Python, Go, and TypeScript.</p>
    <ul class="footer-links">
      {
        socialLinks.map((link) => (
          <li>
            <a href={link.href} rel={link.rel} target={link.href.startsWith('http') ? '_blank' : undefined}>
              {link.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href="/contact">Contact</a>
      </li>
      <li>
        <a href={siteConfig.rssPath}>RSS</a>
      </li>
    </ul>
  </div>
</footer>
