<% content_for :title, "Stephen Sawyer · dunamismax" %>
<% content_for :description, "Stephen Sawyer is a full-stack Ruby on Rails developer, open source advocate, and privacy/security-minded builder with 15 years in IT." %>

<section class="hero-section">
  <div class="hero-background" aria-hidden="true"></div>

  <div class="section-inner hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Ruby on Rails · full-stack · self-hosted</p>
      <h1>Rails software that stays yours.</h1>
      <p class="lede">
        Full-stack Ruby on Rails developer. Open source, privacy, and security
        advocate. Fifteen years in IT, building systems that have to keep
        working after the demo is over.
      </p>
      <p class="lede">
        <strong>Ruby and Rails are my default because they let me ship fastest.</strong>
        I use other tools when the problem clearly calls for them, but Rails is
        where I reach first for durable products, dashboards, APIs, and
        self-hosted web apps.
      </p>

      <div class="hero-actions">
        <%= link_to "See Rails work", projects_path, class: "button button-primary" %>
        <%= link_to "Get in touch", contact_path, class: "button button-secondary" %>
      </div>

      <div class="stack-row" aria-label="Primary stack">
        <span class="stack-chip stack-chip--strong">Ruby</span>
        <span class="stack-chip stack-chip--strong">Rails 8</span>
        <span class="stack-chip">Hotwire</span>
        <span class="stack-chip">ViewComponent</span>
        <span class="stack-chip">Tailwind CSS</span>
        <span class="stack-chip">PostgreSQL</span>
        <span class="stack-chip">SQLite</span>
        <span class="stack-chip">Puma</span>
        <span class="stack-chip">Caddy</span>
      </div>

      <p class="fine-print">
        This site is a Rails 8.1 application, rendered on request and served
        from a single Ubuntu box. Code lives on
        <%= link_to "GitHub", "https://github.com/dunamismax/dunamismax.com", rel: "noopener noreferrer me", target: "_blank" %>
        and mirrors to
        <%= link_to "Codeberg", "https://codeberg.org/dunamismax/dunamismax.com", rel: "noopener noreferrer me", target: "_blank" %>.
      </p>
    </div>

    <div>
      <% if @latest_post %>
        <%= link_to post_path(@latest_post), class: "latest-card" do %>
          <span class="latest-card__kicker">Latest post</span>
          <span class="latest-card__title"><%= @latest_post.title %></span>
          <span class="latest-card__meta">
            <%= @latest_post.published_on.strftime("%b %-d, %Y") %> ·
            <%= reading_time(@latest_post.body_html) %>
          </span>
          <span class="latest-card__description"><%= @latest_post.description %></span>
        <% end %>
      <% end %>

      <nav class="nav-card-grid" aria-label="Quick navigation">
        <%= link_to projects_path, class: "nav-card" do %>
          <span class="nav-card__title">Projects</span>
          <span class="nav-card__detail">Rails apps, self-hosted products, and the MTG tools I still maintain.</span>
        <% end %>
        <%= link_to posts_path, class: "nav-card" do %>
          <span class="nav-card__title">Blog</span>
          <span class="nav-card__detail">Rails build logs, deployment notes, and practical system decisions.</span>
        <% end %>
        <%= link_to about_path, class: "nav-card" do %>
          <span class="nav-card__title">About</span>
          <span class="nav-card__detail">Ruby-first, privacy-minded, low-ceremony engineering.</span>
        <% end %>
        <%= link_to contact_path, class: "nav-card" do %>
          <span class="nav-card__title">Contact</span>
          <span class="nav-card__detail">Email, Signal, GitHub, Codeberg, and site source.</span>
        <% end %>
      </nav>
    </div>
  </div>
</section>

<section class="signal-bar">
  <div class="section-inner signal-grid">
    <p><span></span>Ruby/Rails first</p>
    <p><span></span>Full-stack product work</p>
    <p><span></span>Privacy-aware systems</p>
    <p><span></span>15 years in IT</p>
  </div>
</section>

<section class="page-section">
  <div class="section-inner">
    <div class="section-heading">
      <p class="eyebrow">Featured projects</p>
      <h2>Rails work with real operating shape.</h2>
      <p>
        A short list of current and representative work: Rails products first,
        with the Magic tooling that still earns its place.
      </p>
    </div>

    <ul class="post-list">
      <% @featured_projects.each do |project| %>
        <li>
          <article class="project-card">
            <div class="project-card__head">
              <h3 class="project-card__name"><%= project.name %></h3>
              <span class="project-status project-status--<%= project.status %>">
                <%= project_status_label(project.status) %>
              </span>
            </div>
            <p class="project-card__tagline"><%= project.tagline %></p>
            <div class="project-card__foot">
              <div class="project-card__stack">
                <% project.stack_list.each do |tech| %>
                  <span class="stack-chip"><%= tech %></span>
                <% end %>
              </div>
              <div class="project-card__links">
                <% if project.url.present? %>
                  <%= link_to "live ↗", project.url, rel: "noopener noreferrer", target: "_blank" %>
                <% end %>
                <% if project.public_repo? %>
                  <%= link_to "repo ↗", project.repo, rel: "noopener noreferrer", target: "_blank" %>
                <% end %>
              </div>
            </div>
          </article>
        </li>
      <% end %>
    </ul>

    <p class="section-foot">
      <%= link_to "See every project", projects_path, class: "section-link" %>
    </p>
  </div>
</section>
