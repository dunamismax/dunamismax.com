# Caddyfile for dunamismax.com
#
# Sits on the host as a reverse proxy in front of the Docker container.
# TLS is handled by Caddy on the host. The container runs Uvicorn on port 8080.

dunamismax.com {
    encode zstd gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "0"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    reverse_proxy localhost:8080
}
