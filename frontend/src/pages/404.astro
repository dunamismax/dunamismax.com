---
import { getPageContract } from '../config/site'
import BaseLayout from '../layouts/BaseLayout.astro'

const page = getPageContract('not-found')
---

<BaseLayout description={page.description} pageTitle={page.title} path={page.path} robotsContent="noindex, nofollow">
  <div class="not-found">
    <h1>404</h1>
    <p>The page you were looking for does not exist, or it moved.</p>
    <a href="/">← Home</a>
  </div>
</BaseLayout>
