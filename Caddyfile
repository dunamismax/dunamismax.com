# Caddyfile for dunamismax.com
#
# This is the host-level vhost block that should live in /etc/caddy/Caddyfile on
# the production server. Caddy terminates TLS and reverse-proxies to the Puma
# process, which is launched by the dunamismax-web systemd unit and binds to
# 127.0.0.1:8082. Cloudflare proxies the public domain in front of this.

www.dunamismax.com {
    redir https://dunamismax.com{uri} permanent
}

dunamismax.com {
    encode zstd gzip

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Referrer-Policy "strict-origin-when-cross-origin"
        X-XSS-Protection "0"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    reverse_proxy 127.0.0.1:8082 {
        header_up X-Forwarded-Proto https
        header_up X-Real-IP {remote_host}
    }
}
