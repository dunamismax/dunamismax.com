{
  "name": "dunamismax-site-assets",
  "private": true,
  "version": "0.1.0",
  "description": "Tailwind asset pipeline for dunamismax.com",
  "scripts": {
    "build:css": "tailwindcss -i src/main/tailwind/input.css -o src/main/resources/static/css/site.css --minify",
    "watch:css": "tailwindcss -i src/main/tailwind/input.css -o src/main/resources/static/css/site.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0"
  }
}
