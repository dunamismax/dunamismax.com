---
import SiteFooter from '../components/SiteFooter.astro'
import SiteHeader from '../components/SiteHeader.astro'
import { siteConfig, toAbsoluteUrl } from '../config/site'
import { buildPersonStructuredData, buildWebsiteStructuredData } from '../lib/structured-data'
import '../styles/global.css'

type Props = {
  pageTitle: string
  description: string
  path: string
  ogType?: 'website' | 'article'
  articlePublishedTime?: string
  articleTags?: string[]
  robotsContent?: string
}

const {
  pageTitle,
  description,
  path,
  ogType = 'website',
  articlePublishedTime,
  articleTags = [],
  robotsContent,
} = Astro.props as Props

const canonicalUrl = toAbsoluteUrl(path)
const socialImageUrl = toAbsoluteUrl(siteConfig.socialImagePath)
const websiteStructuredData = buildWebsiteStructuredData()
const personStructuredData = buildPersonStructuredData()
---

<!doctype html>
<html lang={siteConfig.language}>
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1" name="viewport" />
    <title>{pageTitle}</title>
    <meta content={description} name="description" />
    <meta content={siteConfig.author} name="author" />
    <meta content={siteConfig.themeColor} name="theme-color" />
    {robotsContent && <meta content={robotsContent} name="robots" />}

    <meta content={ogType} property="og:type" />
    <meta content={pageTitle} property="og:title" />
    <meta content={description} property="og:description" />
    <meta content={canonicalUrl} property="og:url" />
    <meta content={socialImageUrl} property="og:image" />
    <meta content={siteConfig.name} property="og:site_name" />
    {articlePublishedTime && <meta content={articlePublishedTime} property="article:published_time" />}
    {articleTags.map((tag) => <meta content={tag} property="article:tag" />)}

    <meta content="summary_large_image" name="twitter:card" />
    <meta content={pageTitle} name="twitter:title" />
    <meta content={description} name="twitter:description" />
    <meta content={socialImageUrl} name="twitter:image" />
    <meta content={siteConfig.twitterSite} name="twitter:site" />

    <link href={canonicalUrl} rel="canonical" />
    <link href={siteConfig.faviconPath} rel="icon" type="image/svg+xml" />
    <link
      href={siteConfig.rssPath}
      rel="alternate"
      title={`${siteConfig.name} RSS`}
      type="application/rss+xml"
    />
    <link href="/fonts/InterVariable.woff2" rel="preload" as="font" type="font/woff2" crossorigin />
    <link href="/fonts/JetBrainsMono-Regular.woff2" rel="preload" as="font" type="font/woff2" crossorigin />
    <script type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(personStructuredData)} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader currentPath={path} />
    <main id="main-content">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
