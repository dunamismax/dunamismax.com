---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getReadingTime } from "@/lib/reading-time";

const posts = (await getCollection("blog"))
	.filter((post) => !post.data.draft)
	.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
	title="Blog — Stephen Sawyer"
	description="Technical writing on systems design, self-hosting, Go, C, and operational discipline."
>
	<div class="blog-index">
		<h1>Blog</h1>
		<p class="lead">
			Build logs, systems thinking, craft, and stack philosophy.
		</p>

		{
			posts.length === 0 ? (
				<p class="empty">No posts yet. Check back soon.</p>
			) : (
				<ul class="post-list" role="list">
					{posts.map((post) => (
						<li class="post-row">
							<div class="post-meta">
								<time datetime={post.data.date.toISOString().split("T")[0]}>
									{post.data.date.toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
										day: "numeric",
									})}
								</time>
								<span class="reading-time">
									{getReadingTime(post.body ?? "")}
								</span>
							</div>
							<a href={`/blog/${post.id}`} class="post-title">
								{post.data.title}
							</a>
							<p class="post-excerpt">{post.data.description}</p>
						</li>
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>

<style>
	.blog-index {
		max-width: var(--content-width);
		margin: 0 auto;
	}

	.blog-index h1 {
		margin-bottom: var(--space-4);
	}

	.lead {
		color: var(--text-secondary);
		margin-bottom: var(--space-12);
	}

	.empty {
		color: var(--text-tertiary);
	}

	.post-list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
	}

	.post-row {
		padding-bottom: var(--space-8);
		border-bottom: 1px solid var(--border);
	}

	.post-row:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.post-meta {
		display: flex;
		gap: var(--space-4);
		margin-bottom: var(--space-2);
	}

	.post-meta time {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-tertiary);
	}

	.reading-time {
		font-family: var(--font-mono);
		font-size: var(--text-sm);
		color: var(--text-tertiary);
	}

	.post-title {
		font-family: var(--font-mono);
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--text-primary);
		text-decoration: none;
		display: block;
		margin-bottom: var(--space-2);
		transition: color var(--duration-fast) var(--easing);
	}

	.post-title:hover {
		color: var(--accent);
	}

	.post-excerpt {
		font-size: var(--text-sm);
		color: var(--text-secondary);
		line-height: var(--leading-normal);
		margin: 0;
	}
</style>
