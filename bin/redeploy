#!/usr/bin/env bash
# bin/redeploy - single-command deploy loop for dunamismax.com on this VM.
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

export PATH="/home/sawyer/.local/share/mise/installs/ruby/4.0.3/bin:/home/sawyer/.local/share/mise/installs/node/24.13.1/bin:$PATH"
export BUNDLE_GEMFILE="$APP_ROOT/Gemfile"
export BUNDLE_USER_HOME="$APP_ROOT/tmp/bundler"
export RAILS_ENV=production

set -a
# shellcheck disable=SC1091
. /etc/dunamismax-web/env
set +a

echo "==> [1/7] git pull --ff-only"
git pull --ff-only

echo "==> [2/7] bundle install (without development:test)"
bundle config set --local without 'development:test' >/dev/null
bundle check >/dev/null 2>&1 || bundle install

echo "==> [3/7] rails db:prepare"
bundle exec rails db:prepare

echo "==> [4/7] rails db:seed"
bundle exec rails db:seed

echo "==> [5/7] rails assets:precompile"
SECRET_KEY_BASE_DUMMY=1 bundle exec rails assets:precompile

echo "==> [6/7] systemctl restart dunamismax-web"
if [ -n "${SUDO_PASS:-}" ]; then
  echo "$SUDO_PASS" | sudo -S -p '' systemctl restart dunamismax-web.service
else
  sudo systemctl restart dunamismax-web.service
fi

echo "==> [7/7] health check"
sleep 3
for i in 1 2 3 4 5; do
  code="$(curl -sS -o /dev/null -w "%{http_code}" https://dunamismax.com/up || true)"
  if [ "$code" = "200" ]; then
    echo "    https://dunamismax.com/up -> 200 OK"
    echo "==> redeploy complete"
    exit 0
  fi

  echo "    attempt $i: /up returned $code, retrying..."
  sleep 2
done

echo "!! /up did not return 200 after retries. Recent service logs:" >&2
if [ -n "${SUDO_PASS:-}" ]; then
  echo "$SUDO_PASS" | sudo -S -p '' journalctl -u dunamismax-web --no-pager -n 40 >&2
else
  sudo journalctl -u dunamismax-web --no-pager -n 40 >&2
fi
exit 1
