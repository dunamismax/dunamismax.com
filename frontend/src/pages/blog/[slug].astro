---
import { type CollectionEntry, getCollection, render } from 'astro:content'

import BaseLayout from '../../layouts/BaseLayout.astro'
import { formatDateLong, getReadingTime, isPublishedPost, sortPosts } from '../../lib/blog'
import { buildBlogPostingStructuredData } from '../../lib/structured-data'

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('blog', isPublishedPost))

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

type Props = {
  post: CollectionEntry<'blog'>
}

const { post } = Astro.props as Props
const { Content } = await render(post)
const pageTitle = `${post.data.title} -- Stephen Sawyer`
const articlePath = `/blog/${post.slug}/`
const blogPostingStructuredData = buildBlogPostingStructuredData({
  title: post.data.title,
  description: post.data.description,
  path: articlePath,
  publishedTime: post.data.date.toISOString(),
  tags: post.data.tags,
})
---

<BaseLayout
  articlePublishedTime={post.data.date.toISOString()}
  articleTags={post.data.tags}
  description={post.data.description}
  ogType="article"
  pageTitle={pageTitle}
  path={articlePath}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingStructuredData)} />
  </Fragment>
  <article class="mx-auto max-w-[--width-content]">
    <header class="mb-14">
      <h1 class="mb-4 text-3xl tracking-tight sm:text-4xl">{post.data.title}</h1>
      <div class="flex items-center gap-2 font-[--font-mono] text-sm text-[--color-text-tertiary]">
        <time datetime={post.data.date.toISOString().slice(0, 10)}>
          {formatDateLong(post.data.date)}
        </time>
        <span class="text-[--color-border]">·</span>
        <span>{getReadingTime(post.body)}</span>
      </div>
      {
        post.data.tags.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-2">
            {post.data.tags.map((tag: string) => (
              <span class="rounded-[--radius-md] border border-[--color-border] px-2 py-0.5 font-[--font-mono] text-xs text-[--color-text-tertiary]">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="mt-16 border-t border-[--color-border] pt-8">
      <a
        class="font-[--font-mono] text-sm text-[--color-accent] no-underline hover:text-[--color-accent-hover]"
        href="/blog/"
      >
        ← All posts
      </a>
    </footer>
  </article>
</BaseLayout>
