---
import { type CollectionEntry, getCollection } from 'astro:content'

import { getPageContract } from '../config/site'
import BaseLayout from '../layouts/BaseLayout.astro'
import { groupProjects, type ProjectRecord, STATUS_LABELS } from '../lib/projects'

const page = getPageContract('projects')
const projectEntries = await getCollection('projects')
const projects: ProjectRecord[] = projectEntries.map((entry: CollectionEntry<'projects'>) => ({
  id: entry.id,
  ...entry.data,
}))
const groups = groupProjects(projects)

const statusClasses: Record<string, string> = {
  active: 'bg-emerald-400/6 text-(--color-success)',
  shipped: 'bg-(--color-accent-muted) text-(--color-accent)',
  'phase-0': 'bg-amber-400/6 text-(--color-warning)',
  legacy: 'bg-(--color-bg-tertiary) text-(--color-text-tertiary)',
}
---

<BaseLayout description={page.description} pageTitle={page.title} path={page.path}>
  <div class="mx-auto max-w-(--width-content)">
    <h1 class="mb-4 text-4xl tracking-tight">Projects</h1>
    <p class="mb-14 text-(--color-text-secondary)">
      A selection of public work across products, infrastructure, and developer
      tooling. Some of these are actively evolving, others are shipped references,
      but all reflect the kind of software I like to build.
    </p>

    {
      groups.map((group) => (
        <section class="mb-14">
          <h2 class="mb-2 border-b border-(--color-border) pb-2 text-lg text-(--color-text-secondary)">
            {group.label}
          </h2>
          <p class="mb-6 text-sm text-(--color-text-tertiary)">{group.description}</p>
          <ul class="flex list-none flex-col gap-4 p-0">
            {group.projects.map((project) => (
              <li class="rounded-(--radius-md) border border-(--color-border) bg-(--color-bg-secondary) p-6">
                <div class="mb-2 flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
                  <h3 class="text-base font-medium">{project.name}</h3>
                  <span
                    class:list={[
                      'shrink-0 rounded-(--radius-md) font-mono text-xs px-2 py-0.5',
                      statusClasses[project.status] ?? '',
                    ]}
                  >
                    {STATUS_LABELS[project.status]}
                  </span>
                </div>
                <p class="mb-4 text-sm leading-normal text-(--color-text-secondary)">
                  {project.tagline}
                </p>
                <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
                  <div class="flex flex-wrap gap-2">
                    {project.stack.map((tech) => (
                      <span class="rounded-(--radius-md) border border-(--color-border) px-2 py-0.5 font-mono text-xs text-(--color-text-tertiary)">
                        {tech}
                      </span>
                    ))}
                  </div>
                  <div class="flex shrink-0 flex-wrap gap-4">
                    {project.url && (
                      <a
                        class="font-mono text-sm text-(--color-accent) no-underline hover:text-(--color-accent-hover)"
                        href={project.url}
                        rel="noopener noreferrer"
                        target="_blank"
                      >
                        read it →
                      </a>
                    )}
                    {project.visibility === 'public' && project.repo && (
                      <a
                        class="font-mono text-sm text-(--color-accent) no-underline hover:text-(--color-accent-hover)"
                        href={project.repo}
                        rel="noopener noreferrer"
                        target="_blank"
                      >
                        repo →
                      </a>
                    )}
                    {project.visibility === 'private' && (
                      <span class="font-mono text-sm text-(--color-text-tertiary)">
                        private repo
                      </span>
                    )}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</BaseLayout>
