(static_defaults) {
	root * /usr/share/caddy
	encode zstd gzip
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-XSS-Protection "0"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
}

:80 {
	handle_errors {
		@404 expression {err.status_code} == 404
		handle @404 {
			import static_defaults
			header Cache-Control "no-cache, no-store, must-revalidate"
			rewrite * /404.html
			file_server
		}
	}

	# Fonts: immutable for a year.
	@fonts path /fonts/*
	handle @fonts {
		import static_defaults
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Hashed CSS and JS: immutable for a year.
	@hashed path_regexp hashed \.(css|js)$
	handle @hashed {
		import static_defaults
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Images and icons: cache for a week.
	@images path_regexp images \.(png|jpg|jpeg|gif|webp|avif|svg|ico)$
	handle @images {
		import static_defaults
		header Cache-Control "public, max-age=604800"
		file_server
	}

	# Files with explicit HTML or XML extensions: always revalidate.
	@html path_regexp html \.(html|xml)$
	handle @html {
		import static_defaults
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}

	# Default: HTML pages without extensions.
	handle {
		import static_defaults
		try_files {path} {path}.html {path}/index.html
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}
}
