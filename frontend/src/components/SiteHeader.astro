---
import { navLinks } from '../config/site'

type Props = {
  currentPath: string
}

const { currentPath } = Astro.props as Props
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a class="nav-logo" href="/">dunamismax</a>
    <ul class="nav-links">
      {
        navLinks.map((link) => (
          <li>
            <a aria-current={link.matches(currentPath) ? 'page' : undefined} href={link.href}>
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
