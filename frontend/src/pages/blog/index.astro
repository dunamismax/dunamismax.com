---
import { getCollection } from 'astro:content'

import { getPageContract } from '../../config/site'
import BaseLayout from '../../layouts/BaseLayout.astro'
import { formatDate, getReadingTime, isPublishedPost, sortPosts } from '../../lib/blog'

const page = getPageContract('blog')
const posts = sortPosts(await getCollection('blog', isPublishedPost))
---

<BaseLayout description={page.description} pageTitle={page.title} path={page.path}>
  <div class="blog-index">
    <h1>Blog</h1>
    <p class="lead">Build logs, systems thinking, craft, and stack philosophy.</p>

    {
      posts.length > 0 ? (
        <ul class="post-list">
          {posts.map((post) => (
            <li class="post-row">
              <div class="post-meta">
                <time datetime={post.data.date.toISOString().slice(0, 10)}>
                  {formatDate(post.data.date)}
                </time>
                <span class="reading-time">{getReadingTime(post.body)}</span>
              </div>
              <a class="post-title" href={`/blog/${post.slug}`}>
                {post.data.title}
              </a>
              <p class="post-excerpt">{post.data.description}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty">No posts yet. Check back soon.</p>
      )
    }
  </div>
</BaseLayout>
