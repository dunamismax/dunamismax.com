---
import { getPageContract } from '../config/site'
import BaseLayout from '../layouts/BaseLayout.astro'

const page = getPageContract('home')
---

<BaseLayout description={page.description} pageTitle={page.title} path={page.path}>
  <div class="home">
    <section class="hero">
      <h1>Stephen Sawyer</h1>
      <p class="tagline">I build self-hostable systems software.</p>
      <p class="stack">
        Most of it lives in <strong>Python</strong>, <strong>Go</strong>, and
        <strong>Rust</strong>, with server-rendered frontends on the browser-facing side.
        Local-first, operator-friendly, relational data, single-binary where possible.
      </p>
    </section>

    <nav class="home-nav" aria-label="Quick navigation">
      <a class="nav-card" href="/projects">
        <span class="nav-card-label">Projects</span>
        <span class="nav-card-desc">What I'm building</span>
      </a>
      <a class="nav-card" href="/blog">
        <span class="nav-card-label">Blog</span>
        <span class="nav-card-desc">How I think about it</span>
      </a>
      <a class="nav-card" href="/about">
        <span class="nav-card-label">About</span>
        <span class="nav-card-desc">Who I am</span>
      </a>
      <a class="nav-card" href="/contact">
        <span class="nav-card-label">Contact</span>
        <span class="nav-card-desc">Get in touch</span>
      </a>
    </nav>
  </div>
</BaseLayout>
